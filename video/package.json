{
  "name": "@vaultmark/video",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "audio": "node scripts/generate-audio.mjs",
    "capture": "node scripts/capture-website-screenshots.mjs",
    "studio": "remotion studio src/index.ts",
    "dev": "remotion studio src/index.ts",
    "compositions": "remotion compositions src/index.ts",
    "still": "remotion still src/index.ts VaultmarkProductVideo out/poster.png --frame=120",
