{
  "name": "vaultmark",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "dev": "pnpm --filter @vaultmark/web dev",
    "build": "pnpm --filter @vaultmark/web build",
    "lint": "pnpm --filter @vaultmark/web lint",
    "typecheck": "pnpm --filter @vaultmark/web typecheck",
    "ingest": "pnpm --filter @vaultmark/ingest start",
    "parity:step1": "node scripts/parity-step1.mjs && node scripts/parity-icons.mjs && node scripts/parity-data.mjs && node scripts/parity-bodies.mjs",
    "parity:step2": "node scripts/parity-step2.mjs",
    "parity:step3": "node scripts/parity-step3.mjs",
    "parity:step4": "node scripts/parity-step4.mjs",
    "parity": "pnpm parity:step1 && pnpm parity:step2 && pnpm parity:step3 && pnpm parity:step4",
    "visual": "node scripts/parity-visual.mjs"
  },
  "devDependencies": {
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  }
}
