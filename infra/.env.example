# Vaultmark configuration — full reference in docs/configuration.md
# Copy to web/.env.local for local dev, or use as --env-file for Docker.

# Vault (required: VAULT_BUCKET)
VAULT_ID=default
VAULT_BUCKET=my-vault-bucket
VAULT_PREFIX=
VAULT_REGION=us-east-1

# AWS credentials — leave blank to use the standard credential chain
# (instance role, ECS task role, IRSA, ~/.aws). Prefer roles over keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock — only used when FEATURE_AGENT / FEATURE_CURATE are on.
# Use the us./eu. cross-region inference profile matching your region.
BEDROCK_MODEL=us.amazon.nova-2-lite-v1:0
BEDROCK_REGION=us-east-1

# Curate Lambda — required only for FEATURE_CURATE (see infra/lambda/curate)
#CURATE_LAMBDA_ARN=
#CURATE_LAMBDA_REGION=us-east-1

# Default user id for personal-space paths (users/<id>/...).
# NEXT_PUBLIC_VAULT_USER_ID is inlined into the web build at build time;
# VAULT_USER_ID is the runtime equivalent for the Lambda and ingest CLI.
#NEXT_PUBLIC_VAULT_USER_ID=default
#VAULT_USER_ID=default

# Feature flags — everything is ON unless set to off/false/0/no/disabled.
# Full reference: docs/feature-flags.md
#FEATURE_AGENT=off
#FEATURE_UPLOAD=off
#FEATURE_CURATE=off
#FEATURE_REINDEX=off
#FEATURE_EDITOR=off
#FEATURE_SEARCH=off
#FEATURE_STAR=off
#FEATURE_PUBLISHING=off

# Debugging
#DEBUG_AGENT=1
