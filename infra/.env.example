# Vault
VAULT_ID=default
VAULT_BUCKET=vaultmark
VAULT_PREFIX=project-vaultmark
VAULT_REGION=us-east-1

# AWS credentials — leave blank to use instance role / ECS task role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LLM
BEDROCK_MODEL=amazon.nova-2-lite-v1:0

# Feature flags — each defaults ON unless set to a falsy token
# (off / false / 0 / no / disabled). Default profile below is:
# plain Markdown browsing + Bedrock ask-wiki agent, no ingest processing.
FEATURE_AGENT=on
FEATURE_CURATE=off
FEATURE_UPLOAD=off
FEATURE_REINDEX=off
FEATURE_SEARCH=off
FEATURE_STAR=off
FEATURE_PUBLISHING=off
# Set FEATURE_EDITOR=on to let the agent save proposed pages.
FEATURE_EDITOR=off
