# Vault
VAULT_ID=default
VAULT_BUCKET=vaultmark
VAULT_PREFIX=project-vaultmark
VAULT_REGION=us-east-1

# AWS credentials — leave blank to use instance role / ECS task role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=

# Postgres — overridden by docker-compose to point at the db service
DATABASE_URL=postgresql+asyncpg://vaultmark:vaultmark@db:5432/vaultmark
