# Vault
VAULT_ID=default
VAULT_BUCKET=your-bucket-name
VAULT_PREFIX=vault                        # S3 key prefix, e.g. "my-vault" or "team/wiki"
VAULT_REGION=us-east-1

# AWS credentials (omit if using instance role / SSO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=                         # leave blank for real S3; set to http://localhost:9000 for MinIO

# Postgres
DATABASE_URL=postgresql+asyncpg://vaultmark:vaultmark@localhost:5432/vaultmark
